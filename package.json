{
  "name": "keycloak-mcp-server",
  "version": "0.1.0",
  "description": "Comprehensive Keycloak administration MCP server (Model Context Protocol). Manage realms, clients, users, roles, groups, identity providers and sessions via MCP tools.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "keycloak-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "keycloak",
    "mcp",
    "model-context-protocol",
    "iam",
    "oauth",
    "openid-connect",
    "admin"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@keycloak/keycloak-admin-client": "^26.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}
