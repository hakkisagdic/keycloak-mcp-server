# Keycloak Admin REST connection for keycloak-mcp-server.
# Copy to .env (git-ignored) or pass these as the MCP server's environment.

KEYCLOAK_URL=http://localhost:8081
# Realm used for authentication + default target (master can administer all realms).
KEYCLOAK_REALM=master

# --- Option A: admin username/password via the built-in admin-cli client ---
KEYCLOAK_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Option B: service-account (client-credentials). If set, takes precedence. ---
# KEYCLOAK_CLIENT_ID=keycloak-mcp-admin
# KEYCLOAK_CLIENT_SECRET=change-me
